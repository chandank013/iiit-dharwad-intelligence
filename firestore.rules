/**
 * IIIT Dharwad Portal - Security Rules Configuration
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based access control (RBAC) model.
 * It uses both Sentinel Collections and JWT Token email pattern matching for 
 * redundant and reliable authorization.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a Professor (Sentinel or Email pattern). */
    function isProfessor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/professor_roles/$(request.auth.uid)) ||
        (request.auth.token.email.matches('.*@iiitdwd\\.ac\\.in$') && !request.auth.token.email.matches('^24bds.*'))
      );
    }

    /** @description Checks if the user is a Student (Sentinel or Email pattern). */
    function isStudent() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/student_roles/$(request.auth.uid)) ||
        request.auth.token.email.matches('^24bds.*@iiitdwd\\.ac\\.in$')
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      // Portfolios are owned by students but can be shared/read by others
      match /portfolio/{portfolioId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // Chatbot interactions - private to user
      match /chatbot_interactions/{interactionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /professor_roles/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    match /student_roles/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create: if isProfessor() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isProfessor() && (resource.data.professorId == request.auth.uid);

      match /assignments/{assignmentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isProfessor() && (request.resource.data.professorId == request.auth.uid || resource.data.professorId == request.auth.uid);
      }

      // Submissions overview
      match /submissions/{submissionId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn() && (request.auth.uid == resource.data.submitterId || request.auth.uid == resource.data.professorId);
        allow create: if isStudent() && request.resource.data.submitterId == request.auth.uid;
        allow update: if isSignedIn() && (request.auth.uid == resource.data.submitterId || request.auth.uid == resource.data.professorId);
      }

      // FIXED: Added rules for course content (announcements, files, links)
      match /content/{contentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isProfessor() && (
          (request.resource != null && request.resource.data.professorId == request.auth.uid) || 
          (resource != null && resource.data.professorId == request.auth.uid)
        );
      }
    }

    match /course_enrollments/{enrollmentId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.professorId);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.professorId);
    }
    
    match /learning_resources/{resourceId} {
      allow get, list: if isSignedIn();
    }

    match /private_messages/{messageId} {
      allow create: if isSignedIn();
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow update: if isSignedIn() && (request.auth.uid == resource.data.receiverId); // e.g., mark as read
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow list, get: if isProfessor();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}