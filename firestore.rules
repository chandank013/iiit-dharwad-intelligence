
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfessor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/professor_roles/$(request.auth.uid)) ||
        (request.auth.token.email.matches('.*@iiitdwd\\.ac\\.in$') && !request.auth.token.email.matches('^24bds.*'))
      );
    }

    function isStudent() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/student_roles/$(request.auth.uid)) ||
        request.auth.token.email.matches('^24bds.*@iiitdwd\\.ac\\.in$')
      );
    }

    // Collection Group rules for tracking submissions across all assignments
    match /{path=**}/submissions/{submissionId} {
      allow list, get: if isSignedIn() && (
        request.auth.uid == resource.data.submitterId || 
        request.auth.uid == resource.data.professorId
      );
      allow create: if isStudent() && request.resource.data.submitterId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.professorId || 
        (request.auth.uid == resource.data.submitterId && resource.data.status != 'graded')
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.submitterId && resource.data.status != 'graded'
      );
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    match /professor_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /student_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create: if isProfessor() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isProfessor() && resource.data.professorId == request.auth.uid;

      match /assignments/{assignmentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isProfessor();

        match /submissions/{submissionId} {
          allow create: if isStudent() && request.resource.data.submitterId == request.auth.uid;
          allow read, update, delete: if isSignedIn() && (
            request.auth.uid == resource.data.submitterId || 
            request.auth.uid == resource.data.professorId
          );
        }
        
        match /rubrics/{rubricId} {
          allow read: if isSignedIn();
          allow write: if isProfessor();
          
          match /criteria/{criterionId} {
             allow read: if isSignedIn();
             allow write: if isProfessor();
          }
        }
      }

      match /content/{contentId} {
        allow get, list: if isSignedIn();
        allow create, delete: if isProfessor();
        // Allow anyone signed in to update likesCount and updatedAt
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'updatedAt']);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
          allow delete: if isProfessor() || (resource != null && resource.data.authorId == request.auth.uid);
        }

        match /likes/{userId} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId);
        }
      }
    }

    match /course_enrollments/{enrollmentId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.professorId);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.professorId);
    }
    
    match /private_messages/{messageId} {
      allow create: if isSignedIn();
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    match /learning_resources/{resourceId} {
      allow read: if isSignedIn();
      allow write: if isProfessor();
    }
  }
}
